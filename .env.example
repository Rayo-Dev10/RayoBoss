# RayoBoss - plantilla de variables.
# Copie este archivo como .env solo si no usa scripts/generate-env.sh.
# Nunca confirme .env en Git.

# OBLIGATORIAS
RAYOBOSS_DEV_PASSWORD=REEMPLAZAR_POR_UNA_CONTRASENA_SEGURA_DE_12_O_MAS_CARACTERES
RAYOBOSS_SECRET=REEMPLAZAR_POR_UN_SECRETO_ALEATORIO_DE_32_O_MAS_CARACTERES

# GENERALES
PORT=3000
RAYOBOSS_STORAGE_PROVIDER=auto
RAYOBOSS_COOKIE_SECURE=auto
RAYOBOSS_SESSION_HOURS=12
RAYOBOSS_ALLOWED_ORIGINS=

# AUDIO Y WEBRTC
RAYOBOSS_FRAME_MS=200
RAYOBOSS_SAMPLE_RATE=22050
RAYOBOSS_GAIN=0.7
RAYOBOSS_LIVE_SECONDS=90
RAYOBOSS_RTC_POLL_MS=900
RAYOBOSS_RTC_ROOM_TTL=900
RAYOBOSS_RTC_CLIENT_TTL=180
RAYOBOSS_RTC_MAX_PARTICIPANTS=8
RAYOBOSS_RTC_MAX_LISTENERS=40

# OPCIONALES: solo configurar si dispone de un servidor TURN real.
# RAYOBOSS_TURN_URL=turns://turn.example.com:5349
# RAYOBOSS_TURN_USERNAME=usuario_turn
# RAYOBOSS_TURN_CREDENTIAL=credencial_turn

# OPCIONALES PARA VPS: endpoints de distribución profesional.
# RAYOBOSS_PUBLIC_AUDIO_URL=https://radio.example.edu/stream
# RAYOBOSS_PUBLIC_VIDEO_URL=https://radio.example.edu/live.mp4
# RAYOBOSS_PUBLIC_HLS_URL=https://radio.example.edu/hls/index.m3u8

# VERCEL BLOB: Vercel las crea al conectar el Blob Store.
# No invente estos valores ni los copie al repositorio.
# BLOB_STORE_ID=
# BLOB_READ_WRITE_TOKEN=
